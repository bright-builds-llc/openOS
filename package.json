{
  "name": "openos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "readme:media": "bun scripts/capture-readme-media.mjs",
    "readme:media:update": "bun scripts/capture-readme-media.mjs --update-tracked",
    "readme:media:check": "bun scripts/capture-readme-media.mjs --check-tracked"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
